NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sandbox: https://api-sandbox.asaas.com/v3 · Produção: https://api.asaas.com/v3
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
# Token que você mesmo escolhe (32-255 chars, sem espaços) e cadastra no Asaas
# ao registrar o webhook — usado para validar que a chamada é mesmo do Asaas.
ASAAS_WEBHOOK_TOKEN=

# Token que você mesmo escolhe; Vercel Cron envia como "Authorization: Bearer
# <CRON_SECRET>" automaticamente quando essa env var existe no projeto.
CRON_SECRET=
